{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "oxlint-effect",
  "version": "0.1.0",
  "description": "Oxlint JS plugin enforcing Effect-first development conventions",
  "license": "MIT",
  "files": [
    "src"
  ],
  "type": "module",
