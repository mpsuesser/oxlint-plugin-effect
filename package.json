{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@mpsuesser/oxlint-plugin-effect",
  "version": "0.1.0",
  "description": "Oxlint JS plugin enforcing Effect-first development conventions",
  "keywords": [
    "effect",
    "eslint",
    "lint",
    "linter",
    "oxc",
    "oxlint",
    "oxlint-plugin",
    "oxlintplugin",
    "plugin",
    "rules",
    "typescript"
  ],
  "homepage": "https://github.com/mpsuesser/oxlint-plugin-effect",
  "bugs": {
    "url": "https://github.com/mpsuesser/oxlint-plugin-effect/issues"
  },
  "license": "MIT",
  "author": "Marc Suesser",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpsuesser/oxlint-plugin-effect.git"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./oxlint": "./src/index.ts"
  },
  "scripts": {
    "build": "vp build",
    "check": "vp check --fix",
    "test": "vitest run",
    "typecheck": "tsgo",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.57.0",
    "effect": "4.0.0-beta.46",
    "effect-oxlint": "^0.1.0"
  },
  "devDependencies": {
    "@effect/tsgo": "^0.1.1",
    "@effect/vitest": "4.0.0-beta.46",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.15",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "effect": "4.0.0-beta.46",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "effect-oxlint@0.1.0": "patches/effect-oxlint@0.1.0.patch"
  }
}
